tment-icon {\n      width: 40px;\n      height: 40px;\n      margin-right: 12px;\n  }\n  \n  .department-icon i {\n      font-size: 20px;\n  }\n  \n  .department-name {\n      font-size: 14px;\n  }\n  \n  .section-stats-section {\n      padding: 15px;\n  }\n  \n  .section-stat-card {\n      padding: 15px;\n      height: 80px;\n      margin-bottom: 15px;\n  }\n  \n  .stat-icon {\n      width: 50px;\n      height: 50px;\n      font-size: 24px;\n      margin-right: 12px;\n  }\n  \n  .stat-number {\n      font-size: 20px;\n  }\n  \n  .stat-label {\n      font-size: 12px;\n  }\n}\n\n@media (max-width: 480px) {\n  .department-card {\n      flex-direction: column;\n      text-align: center;\n      padding: 20px 15px;\n  }\n  \n  .department-icon {\n      margin-right: 0;\n      margin-bottom: 10px;\n  }\n  \n  .department-arrow {\n      display: none;\n  }\n  \n  .category-header {\n      flex-direction: column;\n      align-items: flex-start;\n      gap: 10px;\n  }\n  \n  .category-count {\n      align-self: flex-start;\n  }\n}\n\n/* 动画效果 */\n@keyframes fadeInUp {\n  from {\n      opacity: 0;\n      transform: translateY(20px);\n  }\n  to {\n      opacity: 1;\n      transform: translateY(0);\n  }\n}\n\n.category-section {\n  animation: fadeInUp 0.5s ease forwards;\n}\n\n.category-section:nth-child(1) { animation-delay: 0.1s; }\n.category-section:nth-child(2) { animation-delay: 0.2s; }\n.category-section:nth-child(3) { animation-delay: 0.3s; }\n.category-section:nth-child(4) { animation-delay: 0.4s; }\n.category-section:nth-child(5) { animation-delay: 0.5s; }\n.category-section:nth-child(6) { animation-delay: 0.6s; }\n.category-section:nth-child(7) { animation-delay: 0.7s; }\n\n.section-stat-card {\n  animation: fadeInUp 0.4s ease forwards;\n}\n\n.section-stat-card:nth-child(1) { animation-delay: 0.2s; }\n.section-stat-card:nth-child(2) { animation-delay: 0.3s; }\n.section-stat-card:nth-child(3) { animation-delay: 0.4s; }\n.section-stat-card:nth-child(4) { animation-delay: