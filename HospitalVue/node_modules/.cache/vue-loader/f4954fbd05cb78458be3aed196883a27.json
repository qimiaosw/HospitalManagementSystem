ACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA","file":"SectionIndex.vue","sourceRoot":"src/views","sourcesContent":["<template>\n  <div class=\"section-management\">\n      <!-- 顶部标题区域 -->\n      <div class=\"section-header-section\">\n          <div class=\"section-title-content\">\n              <i class=\"el-icon-office-building section-title-icon\"></i>\n              <h1 class=\"section-page-title\">科室门诊选择</h1>\n              <p class=\"section-page-subtitle\">请选择您需要就诊的科室</p>\n          </div>\n          <div class=\"section-decoration-element\">\n              <div class=\"section-circle section-circle-1\"></div>\n              <div class=\"section-circle section-circle-2\"></div>\n              <div class=\"section-circle section-circle-3\"></div>\n          </div>\n      </div>\n\n      <el-card class=\"section-management-card\" shadow=\"hover\">\n          <!-- 科室分类展示 -->\n          <div class=\"section-category-container\">\n              <!-- 内科 -->\n              <div class=\"category-section internal-medicine\">\n                  <div class=\"category-header\">\n                      <div class=\"category-icon\">\n                          <i class=\"el-icon-first-aid-kit\"></i>\n                      </div>\n                      <div class=\"category-info\">\n                          <h3 class=\"category-title\">内科</h3>\n                          <span class=\"category-count\">{{ inters.length }}个科室</span>\n                      </div>\n                  </div>\n                  <div class=\"department-grid\">\n                      <div \n                          v-for=\"inter in inters\" \n                          :key=\"inter\"\n                          class=\"department-card\"\n                          @click=\"sectionClick(inter)\"\n                      >\n                          <div class=\"department-icon\">\n                              <i class=\"el-icon-first-aid-kit\"></i>\n                          </div>\n                          <div class=\"department-content\">\n                              <h4 class=\"department-name\">{{ inter }}</h4>\n                              <p class=\"department-desc\">内科专科诊疗</p>\n                          </div>\n                          <div class=\"department-arrow\">\n                              <i class=\"el-icon-arrow-right\"></i>\n                          </div>\n                      </div>\n                  </div>\n              </div>\n\n              <!-- 外科 -->\n              <div class=\"category-section surgery\">\n                  <div class=\"category-header\">\n                      <div class=\"category-icon\">\n                          <i class=\"el-icon-scissors\"></i>\n                      </div>\n                      <div class=\"category-info\">\n                          <h3 class=\"category-title\">外科</h3>\n                          <span class=\"category-count\">{{ outs.length }}个科室</span>\n                      </div>\n                  </div>\n                  <div class=\"department-grid\">\n                      <div \n                          v-for=\"out in outs\" \n                          :key=\"out\"\n                          class=\"department-card\"\n                          @click=\"sectionClick(out)\"\n                      >\n                          <div class=\"department-icon\">\n                              <i class=\"el-icon-scissors\"></i>\n                          </div>\n                          <div class=\"department-content\">\n                              <h4 class=\"department-name\">{{ out }}</h4>\n                              <p class=\"department-desc\">外科手术诊疗</p>\n                          </div>\n                          <div class=\"department-arrow\">\n                              <i class=\"el-icon-arrow-right\"></i>\n                          </div>\n                      </div>\n                  </div>\n              </div>\n\n              <!-- 妇产科 -->\n              <div class=\"category-section obstetrics-gynecology\">\n                  <div class=\"category-header\">\n                      <div class=\"category-icon\">\n                          <i class=\"el-icon-female\"></i>\n                      </div>\n                      <div class=\"category-info\">\n                          <h3 class=\"category-title\">妇产科</h3>\n                          <span class=\"category-count\">{{ women.length }}个科室</span>\n                      </div>\n                  </div>\n                  <div class=\"department-grid\">\n                      <div \n                          v-for=\"woman in women\" \n                          :key=\"woman\"\n                          class=\"department-card\"\n                          @click=\"sectionClick(woman)\"\n                      >\n                          <div class=\"department-icon\">\n                              <i class=\"el-icon-female\"></i>\n                          </div>\n                          <div class=\"department-content\">\n                              <h4 class=\"department-name\">{{ woman }}</h4>\n                              <p class=\"department-desc\">妇产专科诊疗</p>\n                          </div>\n                          <div class=\"department-arrow\">\n                              <i class=\"el-icon-arrow-right\"></i>\n                          </div>\n                      </div>\n                  </div>\n              </div>\n\n              <!-- 儿科 -->\n              <div class=\"category-section pediatrics\">\n                  <div class=\"category-header\">\n                      <div class=\"category-icon\">\n                          <i class=\"el-icon-child\"></i>\n                      </div>\n                      <div class=\"category-info\">\n                          <h3 class=\"category-title\">儿科</h3>\n                          <span class=\"category-count\">{{ kids.length }}个科室</span>\n                      </div>\n                  </div>\n                  <div class=\"department-grid\">\n                      <div \n                          v-for=\"kid in kids\" \n                          :key=\"kid\"\n                          class=\"department-card\"\n                          @click=\"sectionClick(kid)\"\n                      >\n                          <div class=\"department-icon\">\n                              <i class=\"el-icon-child\"></i>\n                          </div>\n                          <div class=\"department-content\">\n                              <h4 class=\"department-name\">{{ kid }}</h4>\n                              <p class=\"department-desc\">儿童专科诊疗</p>\n                          </div>\n                          <div class=\"department-arrow\">\n                              <i class=\"el-icon-arrow-right\"></i>\n                          </div>\n                      </div>\n                  </div>\n              </div>\n\n              <!-- 五官科 -->\n              <div class=\"category-section ent-ophthalmology\">\n                  <div class=\"category-header\">\n                      <div class=\"category-icon\">\n                          <i class=\"el-icon-view\"></i>\n                      </div>\n                      <div class=\"category-info\">\n                          <h3 class=\"category-title\">五官科</h3>\n                          <span class=\"category-count\">{{ fives.length }}个科室</span>\n                      </div>\n                  </div>\n                  <div class=\"department-grid\">\n                      <div \n                          v-for=\"five in fives\" \n                          :key=\"five\"\n                          class=\"department-card\"\n                          @click=\"sectionClick(five)\"\n                      >\n                          <div class=\"department-icon\">\n                              <i class=\"el-icon-view\"></i>\n                          </div>\n                          <div class=\"department-content\">\n                              <h4 class=\"department-name\">{{ five }}</h4>\n                              <p class=\"department-desc\">五官专科诊疗</p>\n                          </div>\n                          <div class=\"department-arrow\">\n                              <i class=\"el-icon-arrow-right\"></i>\n                          </div>\n                      </div>\n                  </div>\n              </div>\n\n              <!-- 中医科 -->\n              <div class=\"category-section traditional-chinese\">\n                  <div class=\"category-header\">\n                      <div class=\"category-icon\">\n                          <i class=\"el-icon-orange\"></i>\n                      </div>\n                      <div class=\"category-info\">\n                          <h3 class=\"category-title\">中医科</h3>\n                          <span class=\"category-count\">{{ chineses.length }}个科室</span>\n                      </div>\n                  </div>\n                  <div class=\"department-grid\">\n                      <div \n                          v-for=\"chinese in chineses\" \n                          :key=\"chinese\"\n                          class=\"department-card\"\n                          @click=\"sectionClick(chinese)\"\n                      >\n                          <div class=\"department-icon\">\n                              <i class=\"el-icon-orange\"></i>\n                          </div>\n                          <div class=\"department-content\">\n                              <h4 class=\"department-name\">{{ chinese }}</h4>\n                              <p class=\"department-desc\">中医传统诊疗</p>\n                          </div>\n                          <div class=\"department-arrow\">\n                              <i class=\"el-icon-arrow-right\"></i>\n                          </div>\n                      </div>\n                  </div>\n              </div>\n\n              <!-- 其他科室 -->\n              <div class=\"category-section other-departments\">\n                  <div class=\"category-header\">\n                      <div class=\"category-icon\">\n                          <i class=\"el-icon-more-outline\"></i>\n                      </div>\n                      <div class=\"category-info\">\n                          <h3 class=\"category-title\">其他科室</h3>\n                          <span class=\"category-count\">{{ orthers.length }}个科室</span>\n                      </div>\n                  </div>\n                  <div class=\"department-grid\">\n                      <div \n                          v-for=\"orther in orthers\" \n                          :key=\"orther\"\n                          class=\"department-card\"\n                          @click=\"sectionClick(orther)\"\n                      >\n                          <div class=\"department-icon\">\n                              <i class=\"el-icon-more-outline\"></i>\n                          </div>\n                          <div class=\"department-content\">\n                              <h4 class=\"department-name\">{{ orther }}</h4>\n                              <p class=\"department-desc\">综合专科诊疗</p>\n                          </div>\n                          <div class=\"department-arrow\">\n                              <i class=\"el-icon-arrow-right\"></i>\n                          </div>\n                      </div>\n                  </div>\n              </div>\n          </div>\n\n          <!-- 统计信息 -->\n          <div class=\"section-stats-section\">\n              <el-row :gutter=\"20\">\n                  <el-col :span=\"6\">\n                      <div class=\"section-stat-card total-stat\">\n                          <div class=\"stat-icon\">\n                              <i class=\"el-icon-office-building\"></i>\n                          </div>\n                          <div class=\"stat-content\">\n                              <div class=\"stat-number\">{{ totalDepartments }}</div>\n                              <div class=\"stat-label\">总科室数</div>\n                          </div>\n                      </div>\n                  </el-col>\n                  <el-col :span=\"6\">\n                      <div class=\"section-stat-card internal-stat\">\n                          <div class=\"stat-icon\">\n                              <i class=\"el-icon-first-aid-kit\"></i>\n                          </div>\n                          <div class=\"stat-content\">\n                              <div class=\"stat-number\">{{ inters.length }}</div>\n                              <div class=\"stat-label\">内科科室</div>\n                          </div>\n                      </div>\n                  </el-col>\n                  <el-col :span=\"6\">\n                      <div class=\"section-stat-card surgery-stat\">\n                          <div class=\"stat-icon\">\n                              <i class=\"el-icon-scissors\"></i>\n                          </div>\n                          <div class=\"stat-content\">\n                              <div class=\"stat-number\">{{ outs.length }}</div>\n                              <div class=\"stat-label\">外科科室</div>\n                          </div>\n                      </div>\n                  </el-col>\n                  <el-col :span=\"6\">\n                      <div class=\"section-stat-card other-stat\">\n                          <div class=\"stat-icon\">\n                              <i class=\"el-icon-more-outline\"></i>\n                          </div>\n                          <div class=\"stat-content\">\n                              <div class=\"stat-number\">{{ otherDepartmentsCount }}</div>\n                              <div class=\"stat-label\">其他科室</div>\n                          </div>\n                      </div>\n                  </el-col>\n              </el-row>\n          </div>\n\n          <!-- 操作提示 -->\n          <div class=\"section-tips-section\">\n              <el-alert\n                  title=\"温馨提示\"\n                  description=\"请根据您的症状选择合适的科室，点击科室卡片可查看该科室的医生排班信息\"\n                  type=\"info\"\n                  :closable=\"false\"\n                  show-icon\n                  class=\"section-tips-alert\"\n              >\n              </el-alert>\n          </div>\n      </el-card>\n  </div>\n</template>\n\n<script>\nexport default {\n  name: \"SectionIndex\",\n  data() {\n      return {\n          inters: [\n              \"神经内科\",\n              \"呼吸与危重症医学科\",\n              \"内分泌科\",\n              \"消化内科\",\n              \"心血管内科\",\n              \"肾内科\",\n              \"发热门诊\",\n          ],\n          outs: [\n              \"手足外科\",\n              \"普通外科\",\n              \"肛肠外科\",\n              \"神经外科\",\n              \"泌尿外科\",\n              \"骨科\",\n              \"烧伤整形外科\",\n          ],\n          women: [\"妇科\", \"产科\"],\n          kids: [\"儿科\", \"儿童保健科\"],\n          fives: [\"耳鼻咽喉科\", \"眼科\", \"口腔科\"],\n          chineses: [\"中医科\"],\n          orthers: [\"康复医学科\", \"急诊科\", \"皮肤性病科\", \"功能科\"],\n      };\n  },\n  computed: {\n      // 计算总科室数\n      totalDepartments() {\n          return this.inters.length + this.outs.length + this.women.length + \n                 this.kids.length + this.fives.length + this.chineses.length + \n                 this.orthers.length;\n      },\n      // 计算其他科室数（除内外科外）\n      otherDepartmentsCount() {\n          return this.women.length + this.kids.length + this.fives.length + \n                 this.chineses.length + this.orthers.length;\n      }\n  },\n  methods: {\n      // 科室点击\n      sectionClick(section) {\n          this.$message.success(`正在跳转到 ${section} 医生排班页面`);\n          this.$router.push({ path: '/arrangeDoctor?section=' + section });\n      }\n  }\n};\n</script>\n\n<style lang=\"scss\" scoped>\n.section-management {\n  padding: 20px;\n  background: linear-gradient(135deg, #f5f7fa 0%, #e4e8f0 100%);\n  min-height: 100vh;\n}\n\n/* 顶部标题区域 */\n.section-header-section {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  margin-bottom: 30px;\n  position: relative;\n  padding: 20px 0;\n}\n\n.section-title-content {\n  z-index: 2;\n}\n\n.section-title-icon {\n  font-size: 36px;\n  color: #409eff;\n  margin-bottom: 10px;\n}\n\n.section-page-title {\n  font-size: 28px;\n  font-weight: 600;\n  color: #1f2d3d;\n  margin: 0 0 5px 0;\n  background: linear-gradient(135deg, #409eff 0%, #66b1ff 100%);\n  -webkit-background-clip: text;\n  -webkit-text-fill-color: transparent;\n  background-clip: text;\n}\n\n.section-page-subtitle {\n  font-size: 16px;\n  color: #5a6376;\n  margin: 0;\n}\n\n.section-decoration-element {\n  position: absolute;\n  right: 0;\n  top: 0;\n}\n\n.section-circle {\n  position: absolute;\n  border-radius: 50%;\n  opacity: 0.1;\n}\n\n.section-circle-1 {\n  width: 100px;\n  height: 100px;\n  background: #409eff;\n  top: -30px;\n  right: 0;\n}\n\n.section-circle-2 {\n  width: 70px;\n  height: 70px;\n  background: #67c23a;\n  top: 10px;\n  right: 80px;\n}\n\n.section-circle-3 {\n  width: 50px;\n  height: 50px;\n  background: #e6a23c;\n  top: 40px;\n  right: 40px;\n}\n\n/* 主卡片样式 */\n.section-management-card {\n  border-radius: 16px;\n  border: none;\n  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);\n  overflow: hidden;\n}\n\n.section-management-card:hover {\n  box-shadow: 0 8px 30px rgba(0, 0, 0, 0.12);\n}\n\n/* 科室分类容器 */\n.section-category-container {\n  padding: 20px;\n}\n\n.category-section {\n  margin-bottom: 30px;\n  padding-bottom: 20px;\n  border-bottom: 1px solid #f0f2f5;\n  \n  &:last-child {\n      border-bottom: none;\n      margin-bottom: 0;\n  }\n}\n\n.category-header {\n  display: flex;\n  align-items: center;\n  margin-bottom: 20px;\n  padding: 15px 0;\n}\n\n.category-icon {\n  width: 50px;\n  height: 50px;\n  border-radius: 12px;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  margin-right: 15px;\n  font-size: 24px;\n  color: white;\n}\n\n.internal-medicine .category-icon {\n  background: linear-gradient(135deg, #409eff 0%, #66b1ff 100%);\n}\n\n.surgery .category-icon {\n  background: linear-gradient(135deg, #67c23a 0%, #85ce61 100%);\n}\n\n.obstetrics-gynecology .category-icon {\n  background: linear-gradient(135deg, #e6a23c 0%, #f2b64c 100%);\n}\n\n.pediatrics .category-icon {\n  background: linear-gradient(135deg, #f56c6c 0%, #f78989 100%);\n}\n\n.ent-ophthalmology .category-icon {\n  background: linear-gradient(135deg, #909399 0%, #a6a9ad 100%);\n}\n\n.traditional-chinese .category-icon {\n  background: linear-gradient(135deg, #8e44ad 0%, #9b59b6 100%);\n}\n\n.other-departments .category-icon {\n  background: linear-gradient(135deg, #34495e 0%, #2c3e50 100%);\n}\n\n.category-info {\n  flex: 1;\n}\n\n.category-title {\n  font-size: 20px;\n  font-weight: 600;\n  color: #1f2d3d;\n  margin: 0 0 5px 0;\n}\n\n.category-count {\n  font-size: 14px;\n  color: #909399;\n  background: #f5f7fa;\n  padding: 4px 12px;\n  border-radius: 12px;\n  font-weight: 500;\n}\n\n/* 科室网格布局 */\n.department-grid {\n  display: grid;\n  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));\n  gap: 16px;\n}\n\n.department-card {\n  display: flex;\n  align-items: center;\n  padding: 20px;\n  background: white;\n  border-radius: 12px;\n  border: 1px solid #e6e8eb;\n  cursor: pointer;\n  transition: all 0.3s ease;\n  position: relative;\n  overflow: hidden;\n}\n\n.department-card:hover {\n  transform: translateY(-2px);\n  box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);\n  border-color: #409eff;\n}\n\n.department-card::before {\n  content: '';\n  position: absolute;\n  top: 0;\n  left: -100%;\n  width: 100%;\n  height: 100%;\n  background: linear-gradient(90deg, transparent, rgba(64, 158, 255, 0.1), transparent);\n  transition: left 0.6s ease;\n}\n\n.department-card:hover::before {\n  left: 100%;\n}\n\n.department-icon {\n  width: 50px;\n  height: 50px;\n  border-radius: 10px;\n  background: linear-gradient(135deg, #409eff 0%, #66b1ff 100%);\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  margin-right: 15px;\n  flex-shrink: 0;\n}\n\n.department-icon i {\n  font-size: 24px;\n  color: white;\n}\n\n.department-content {\n  flex: 1;\n}\n\n.department-name {\n  font-size: 16px;\n  font-weight: 600;\n  color: #1f2d3d;\n  margin: 0 0 5px 0;\n}\n\n.department-desc {\n  font-size: 12px;\n  color: #909399;\n  margin: 0;\n}\n\n.department-arrow {\n  color: #c0c4cc;\n  transition: all 0.3s ease;\n}\n\n.department-card:hover .department-arrow {\n  color: