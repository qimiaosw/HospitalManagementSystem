op: -20px;\n  right: -20px;\n  opacity: 0.2;\n}\n\n/* 卡片内容 */\n.card-content {\n  display: flex;\n  align-items: center;\n  margin-bottom: 20px;\n}\n\n.card-icon-section {\n  margin-right: 20px;\n}\n\n.icon-wrapper {\n  width: 70px;\n  height: 70px;\n  border-radius: 16px;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  font-size: 32px;\n  color: white;\n}\n\n.appointment-card .icon-wrapper {\n  background: linear-gradient(135deg, #409eff 0%, #66b1ff 100%);\n}\n\n.hospitalization-card .icon-wrapper {\n  background: linear-gradient(135deg, #67c23a 0%, #85ce61 100%);\n}\n\n.doctor-card .icon-wrapper {\n  background: linear-gradient(135deg, #e6a23c 0%, #f2b64c 100%);\n}\n\n.department-card .icon-wrapper {\n  background: linear-gradient(135deg, #909399 0%, #a6a9ad 100%);\n}\n\n.card-info-section {\n  flex: 1;\n}\n\n.card-title {\n  font-size: 14px;\n  color: #909399;\n  margin: 0 0 8px 0;\n  font-weight: 500;\n}\n\n.card-value {\n  font-size: 32px;\n  font-weight: 700;\n  color: #1f2d3d;\n  margin: 0 0 5px 0;\n  line-height: 1;\n}\n\n.card-label {\n  font-size: 12px;\n  color: #c0c4cc;\n  margin: 0;\n}\n\n.card-trend-section {\n  text-align: right;\n}\n\n.trend-indicator {\n  display: inline-flex;\n  align-items: center;\n  gap: 4px;\n  padding: 4px 8px;\n  border-radius: 12px;\n  font-size: 12px;\n  font-weight: 500;\n}\n\n.trend-indicator.positive {\n  background: rgba(103, 194, 58, 0.1);\n  color: #67c23a;\n}\n\n.trend-indicator.stable {\n  background: rgba(144, 147, 153, 0.1);\n  color: #909399;\n}\n\n/* 卡片底部 */\n.card-footer {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  padding-top: 15px;\n  border-top: 1px solid #f0f2f5;\n}\n\n.footer-info {\n  display: flex;\n  align-items: center;\n  gap: 6px;\n  font-size: 12px;\n  color: #c0c4cc;\n}\n\n.detail-btn {\n  color: #409eff;\n  font-size: 12px;\n  padding: 4px 8px;\n}\n\n.detail-btn:hover {\n  color: #66b1ff;\n  background: rgba(64, 158, 255, 0.1);\n}\n\n/* 快速操作区域 */\n.quick-actions-section {\n  margin-bottom: 30px;\n}\n\n.section-header {\n  display: flex;\n  align-items: center;\n  margin-bottom: 20px;\n  padding: 0 10px;\n}\n\n.quick-action-icon {\n  font-size: 20px;\n  color: #409eff;\n  margin-right: 10px;\n}\n\n.section-title {\n  font-size: 18px;\n  font-weight: 600;\n  color: #1f2d3d;\n  margin: 0;\n}\n\n.action-grid {\n  display: grid;\n  grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));\n  gap: 16px;\n}\n\n.action-card {\n  background: white;\n  border-radius: 12px;\n  padding: 20px;\n  display: flex;\n  align-items: center;\n  gap: 15px;\n  cursor: pointer;\n  transition: all 0.3s ease;\n  border: 1px solid #f0f2f5;\n  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);\n}\n\n.action-card:hover {\n  transform: translateY(-2px);\n  box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);\n  border-color: #409eff;\n}\n\n.action-icon {\n  width: 50px;\n  height: 50px;\n  border-radius: 10px;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  font-size: 20px;\n  color: white;\n}\n\n.appointment-action {\n  background: linear-gradient(135deg, #409eff 0%, #66b1ff 100%);\n}\n\n.record-action {\n  background: linear-gradient(135deg, #67c23a 0%, #85ce61 100%);\n}\n\n.bed-action {\n  background: linear-gradient(135deg, #e6a23c 0%, #f2b64c 100%);\n}\n\n.profile-action {\n  background: linear-gradient(135deg, #909399 0%, #a6a9ad 100%);\n}\n\n.action-content {\n  flex: 1;\n}\n\n.action-content h4 {\n  font-size: 16px;\n  font-weight: 600;\n  color: #1f2d3d;\n  margin: 0 0 4px 0;\n}\n\n.action-content p {\n  font-size: 12px;\n  color: #909399;\n  margin: 0;\n}\n\n.action-arrow {\n  color: #c0c4cc;\n  transition: all 0.3s ease;\n}\n\n.action-card:hover .action-arrow {\n  color: #409eff;\n  transform: translateX(3px);\n}\n\n/* 更新时间区域 */\n.update-time-section {\n  margin-top: 30px;\n}\n\n.update-card {\n  border-radius: 12px;\n  border: none;\n  background: linear-gradient(135deg, #f0f9ff 0%, #e6f3ff 100%);\n}\n\n.update-content {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  padding: 15px 20px;\n}\n\n.update-icon {\n  font-size: 20px;\n  color: #409eff;\n  margin-right: 10px;\n}\n\n.update-info {\n  flex: 1;\n}\n\n.update-text {\n  font-size: 14px;\n  color: #606266;\n}\n\n.update-time {\n  font-size: 14px;\n  font-weight: 600;\n  color: #409eff;\n}\n\n.refresh-btn {\n  background: linear-gradient(135deg, #409eff 0%, #66b1ff 100%);\n  border: none;\n  color: white;\n  border-radius: 6px;\n}\n\n.refresh-btn:hover {\n  box-shadow: 0 2px 8px rgba(64, 158, 255, 0.3);\n}\n\n/* 响应式设计 */\n@media (max-width: 1024px) {\n  .stats-grid {\n      grid-template-columns: repeat(2, 1fr);\n  }\n  \n  .action-grid {\n      grid-template-columns: repeat(2, 1fr);\n  }\n}\n\n@media (max-width: 768px) {\n  .patient-overview-management {\n      padding: 15px;\n  }\n  \n  .overview-header-section {\n      flex-direction: column;\n      text-align: center;\n      margin-bottom: 20px;\n  }\n  \n  .stats-grid {\n      grid-template-columns: 1fr;\n      gap: 15px;\n  }\n  \n  .action-grid {\n      grid-template-columns: 1fr;\n  }\n  \n  .update-content {\n      flex-direction: column;\n      gap: 15px;\n      text-align: center;\n  }\n  \n  .card-content {\n      flex-direction: column;\n      text-align: center;\n      gap: 15px;\n  }\n  \n  .card-icon-section {\n      margin-right: 0;\n  }\n  \n  .card-trend-section {\n      text-align: center;\n  }\n}\n\n@media (max-width: 480px) {\n  .patient-overview-management {\n      padding: 10px;\n  }\n  \n  .overview-page-title {\n      font-size: 24px;\n  }\n  \n  .stat-card {\n      padding: 20px;\n  }\n  \n  .icon-wrapper {\n      width: 60px;\n      height: 60px;\n      font-size: 28px;\n  }\n  \n  .card-value {\n      font-size: 28px;\n  }\n  \n  .action-card {\n      padding: 15px;\n  }\n  \n  .action-icon {\n      width: 40px;\n      height: 40px;\n      font-size: 18px;\n  }\n}\n\n/* 动画效果 */\n@keyframes fadeInUp {\n  from {\n      opacity: 0;\n      transform: translateY(20px);\n  }\n  to {\n      opacity: 1;\n      transform: translateY(0);\n  }\n}\n\n.stat-card {\n  animation: fadeInUp 0.5s ease forwards;\n}\n\n.stat-card:nth-child(1) { animation-delay: 0.1s; }\n.stat-card:nth-child(2) { animation-delay: 0.2s; }\n.stat-card:nth-child(3) { animation-delay: 0.3s; }\n.stat-card:nth-child(4) { animation-delay: 0.4s; }\n\n.action-card {\n  animation: fadeInUp 0.6s ease forwards;\n}\n\n.action-card:nth-child(1) { animation-delay: 0.2s; }\n.action-card:nth-child(2) { animation-delay: 0.3s; }\n.action-card:nth-child(3) { animation-delay: 0.4s; }\n.action-card:nth-child(4) { animation-delay: 0.5s; }\n\n.update-card {\n  animation: fadeInUp 0.7s ease forwards;\n}\n\n/* 加载动画 */\n.refresh-btn .el-icon-loading {\n  animation: spin 1s linear infinite;\n}\n\n@keyframes spin {\n  from { transform: rotate(0deg); }\n  to { transform: rotate(360deg); }\n}\n</style>"]}]}