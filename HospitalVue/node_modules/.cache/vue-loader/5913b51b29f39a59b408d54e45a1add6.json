{"remainingRequest":"D:\\医院管理系统\\HospitalVue\\node_modules\\vue-loader\\lib\\index.js??vue-loader-options!D:\\医院管理系统\\HospitalVue\\src\\components\\DiagnosisResult.vue?vue&type=style&index=0&id=4ed0096e&scoped=true&lang=css&","dependencies":[{"path":"D:\\医院管理系统\\HospitalVue\\src\\components\\DiagnosisResult.vue","mtime":1767412390615},{"path":"D:\\医院管理系统\\HospitalVue\\node_modules\\css-loader\\dist\\cjs.js","mtime":1689001368000},{"path":"D:\\医院管理系统\\HospitalVue\\node_modules\\vue-loader\\lib\\loaders\\stylePostLoader.js","mtime":1689001370000},{"path":"D:\\医院管理系统\\HospitalVue\\node_modules\\postcss-loader\\src\\index.js","mtime":1689001370000},{"path":"D:\\医院管理系统\\HospitalVue\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1689001368000},{"path":"D:\\医院管理系统\\HospitalVue\\node_modules\\vue-loader\\lib\\index.js","mtime":1689001370000}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["DiagnosisResult.vue"],"names":[],"mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AA2NA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA","file":"DiagnosisResult.vue","sourceRoot":"src/components","sourcesContent":["<template>\r\n  <div class=\"diagnosis-result-container\">\r\n    <!-- 诊断结果卡片 -->\r\n    <el-card class=\"result-card\">\r\n      <div slot=\"header\" class=\"card-header\">\r\n        <div class=\"header-title\">\r\n          <i class=\"el-icon-s-claim\"></i>\r\n          <span>AI诊断结果</span>\r\n        </div>\r\n        <div class=\"header-actions\">\r\n          <el-tag :type=\"getSeverityTagType(result.severity)\" size=\"small\">\r\n            {{ result.severity }}\r\n          </el-tag>\r\n        </div>\r\n      </div>\r\n\r\n      <!-- 疾病列表 -->\r\n      <div class=\"result-section\">\r\n        <div class=\"section-title\">\r\n          <i class=\"el-icon-document\"></i>\r\n          <span>可能的疾病</span>\r\n        </div>\r\n        <div class=\"diseases-list\">\r\n          <el-tag\r\n              v-for=\"(disease, index) in result.diseases\"\r\n              :key=\"index\"\r\n              :type=\"getDiseaseTagType(index)\"\r\n              size=\"medium\"\r\n              style=\"margin: 5px\"\r\n          >\r\n            {{ index + 1 }}. {{ disease }}\r\n          </el-tag>\r\n        </div>\r\n      </div>\r\n\r\n      <!-- 推荐科室 -->\r\n      <div class=\"result-section\">\r\n        <div class=\"section-title\">\r\n          <i class=\"el-icon-office-building\"></i>\r\n          <span>推荐科室</span>\r\n        </div>\r\n        <div class=\"department-info\">\r\n          <el-button type=\"primary\" size=\"small\" icon=\"el-icon-star-off\">\r\n            {{ result.department }}\r\n          </el-button>\r\n          <p class=\"reasoning-text\">\r\n            <i class=\"el-icon-info\"></i>\r\n            {{ result.reasoning }}\r\n          </p>\r\n        </div>\r\n      </div>\r\n\r\n      <!-- 严重程度 -->\r\n      <div class=\"result-section\">\r\n        <div class=\"section-title\">\r\n          <i class=\"el-icon-warning\"></i>\r\n          <span>严重程度</span>\r\n        </div>\r\n        <div class=\"severity-info\">\r\n          <el-alert\r\n              :title=\"getSeverityMessage()\"\r\n              :type=\"getSeverityAlertType(result.severity)\"\r\n              :closable=\"false\"\r\n              show-icon\r\n          >\r\n          </el-alert>\r\n        </div>\r\n      </div>\r\n\r\n      <!-- 就医建议 -->\r\n      <div class=\"result-section\">\r\n        <div class=\"section-title\">\r\n          <i class=\"el-icon-s-claim\"></i>\r\n          <span>就医建议</span>\r\n        </div>\r\n        <div class=\"advice-list\">\r\n          <div\r\n              v-for=\"(advice, index) in parseAdvice(result.advice)\"\r\n              :key=\"index\"\r\n              class=\"advice-item\"\r\n          >\r\n            <i class=\"el-icon-check\"></i>\r\n            <span>{{ advice }}</span>\r\n          </div>\r\n        </div>\r\n      </div>\r\n\r\n      <!-- 推荐医生 -->\r\n      <div v-if=\"result.recommendedDoctors && result.recommendedDoctors.length > 0\" class=\"result-section\">\r\n        <div class=\"section-title\">\r\n          <i class=\"el-icon-user-solid\"></i>\r\n          <span>推荐医生</span>\r\n        </div>\r\n        <div class=\"doctors-list\">\r\n          <el-card\r\n              v-for=\"(doctor, index) in result.recommendedDoctors\"\r\n              :key=\"index\"\r\n              class=\"doctor-card\"\r\n              shadow=\"hover\"\r\n          >\r\n            <div class=\"doctor-info\">\r\n              <div class=\"doctor-avatar\">\r\n                <i class=\"el-icon-user\"></i>\r\n              </div>\r\n              <div class=\"doctor-details\">\r\n                <div class=\"doctor-name\">{{ doctor.dName }}</div>\r\n                <div class=\"doctor-title\">{{ doctor.dTitle }}</div>\r\n                <div class=\"doctor-price\">挂号费：¥{{ doctor.dPrice }}</div>\r\n              </div>\r\n            </div>\r\n            <el-button\r\n                type=\"primary\"\r\n                size=\"small\"\r\n                @click=\"handleAppointment(doctor)\"\r\n                icon=\"el-icon-s-claim\"\r\n            >\r\n              立即预约\r\n            </el-button>\r\n          </el-card>\r\n        </div>\r\n      </div>\r\n\r\n      <!-- 免责声明 -->\r\n      <div class=\"result-section disclaimer\">\r\n        <el-alert\r\n            title=\"免责声明\"\r\n            type=\"warning\"\r\n            :closable=\"false\"\r\n            show-icon\r\n        >\r\n          <template>\r\n            <p>1. AI诊断结果仅供参考，不能替代专业医生的诊断</p>\r\n            <p>2. 如果症状严重或持续恶化，请立即就医</p>\r\n            <p>3. 请以医院实际诊断为准</p>\r\n          </template>\r\n        </el-alert>\r\n      </div>\r\n    </el-card>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: 'DiagnosisResult',\r\n  props: {\r\n    result: {\r\n      type: Object,\r\n      required: true\r\n    }\r\n  },\r\n  methods: {\r\n    /**\r\n     * 解析就医建议\r\n     */\r\n    parseAdvice(advice) {\r\n      if (!advice) return []\r\n      return advice.split(/；|;|。/)\r\n          .map(item => item.trim())\r\n          .filter(item => item)\r\n    },\r\n\r\n    /**\r\n     * 获取严重程度标签类型\r\n     */\r\n    getSeverityTagType(severity) {\r\n      const typeMap = {\r\n        '轻微': 'success',\r\n        '中等': 'warning',\r\n        '严重': 'danger',\r\n        '紧急': 'danger'\r\n      }\r\n      return typeMap[severity] || 'info'\r\n    },\r\n\r\n    /**\r\n     * 获取严重程度警告类型\r\n     */\r\n    getSeverityAlertType(severity) {\r\n      const typeMap = {\r\n        '轻微': 'success',\r\n        '中等': 'warning',\r\n        '严重': 'error',\r\n        '紧急': 'error'\r\n      }\r\n      return typeMap[severity] || 'info'\r\n    },\r\n\r\n    /**\r\n     * 获取严重程度消息\r\n     */\r\n    getSeverityMessage() {\r\n      const messageMap = {\r\n        '轻微': '症状较轻，建议观察，必要时就医',\r\n        '中等': '症状明显，建议尽快就医',\r\n        '严重': '症状严重，建议立即就医',\r\n        '紧急': '情况紧急，请立即拨打120或前往急诊'\r\n      }\r\n      return messageMap[this.result.severity] || '请根据实际情况决定是否就医'\r\n    },\r\n\r\n    /**\r\n     * 获取疾病标签类型\r\n     */\r\n    getDiseaseTagType(index) {\r\n      const types = ['primary', 'success', 'info', 'warning', 'danger']\r\n      return types[index % types.length]\r\n    },\r\n\r\n    /**\r\n     * 处理预约\r\n     */\r\n    handleAppointment(doctor) {\r\n      this.$emit('make-appointment', doctor)\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n.diagnosis-result-container {\r\n  padding: 20px;\r\n}\r\n\r\n.result-card {\r\n  border-radius: 8px;\r\n  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.1);\r\n}\r\n\r\n.card-header {\r\n  display: flex;\r\n  justify-content: space-between;\r\n  align-items: center;\r\n}\r\n\r\n.header-title {\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 8px;\r\n  font-size: 18px;\r\n  font-weight: 500;\r\n  color: #333;\r\n}\r\n\r\n.header-title i {\r\n  color: #409EFF;\r\n}\r\n\r\n.result-section {\r\n  margin-bottom: 25px;\r\n  padding-bottom: 20px;\r\n  border-bottom: 1px solid #f0f0f0;\r\n}\r\n\r\n.result-section:last-child {\r\n  border-bottom: none;\r\n  margin-bottom: 0;\r\n  padding-bottom: 0;\r\n}\r\n\r\n.section-title {\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 8px;\r\n  font-size: 16px;\r\n  font-weight: 500;\r\n  color: #333;\r\n  margin-bottom: 12px;\r\n}\r\n\r\n.section-title i {\r\n  color: #409EFF;\r\n}\r\n\r\n.diseases-list {\r\n  display: flex;\r\n  flex-wrap: wrap;\r\n  gap: 8px;\r\n}\r\n\r\n.department-info {\r\n  display: flex;\r\n  flex-direction: column;\r\n  gap: 10px;\r\n}\r\n\r\n.reasoning-text {\r\n  font-size: 14px;\r\n  color: #666;\r\n  line-height: 1.6;\r\n  padding: 10px;\r\n  background: #f5f5f5;\r\n  border-radius: 4px;\r\n}\r\n\r\n.reasoning-text i {\r\n  color: #409EFF;\r\n  margin-right: 5px;\r\n}\r\n\r\n.severity-info {\r\n  margin-top: 10px;\r\n}\r\n\r\n.advice-list {\r\n  display: flex;\r\n  flex-direction: column;\r\n  gap: 8px;\r\n}\r\n\r\n.advice-item {\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 8px;\r\n  padding: 8px 12px;\r\n  background: #f0f9ff;\r\n  border-left: 3px solid #409EFF;\r\n  border-radius: 4px;\r\n  font-size: 14px;\r\n  color: #333;\r\n}\r\n\r\n.advice-item i {\r\n  color: #67C23A;\r\n  font-size: 16px;\r\n}\r\n\r\n.doctors-list {\r\n  display: grid;\r\n  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));\r\n  gap: 15px;\r\n}\r\n\r\n.doctor-card {\r\n  border-radius: 6px;\r\n}\r\n\r\n.doctor-info {\r\n  display: flex;\r\n  gap: 12px;\r\n  margin-bottom: 15px;\r\n}\r\n\r\n.doctor-avatar {\r\n  width: 60px;\r\n  height: 60px;\r\n  border-radius: 50%;\r\n  background: #f0f0f0;\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  font-size: 24px;\r\n  color: #999;\r\n}\r\n\r\n.doctor-details {\r\n  flex: 1;\r\n}\r\n\r\n.doctor-name {\r\n  font-size: 16px;\r\n  font-weight: 500;\r\n  color: #333;\r\n  margin-bottom: 5px;\r\n}\r\n\r\n.doctor-title {\r\n  font-size: 14px;\r\n  color: #666;\r\n  margin-bottom: 5px;\r\n}\r\n\r\n.doctor-price {\r\n  font-size: 14px;\r\n  color: #f56c6c;\r\n  font-weight: 500;\r\n}\r\n\r\n.disclaimer {\r\n  margin-top: 20px;\r\n}\r\n\r\n.disclaimer p {\r\n  margin: 5px 0;\r\n  font-size: 13px;\r\n  color: #666;\r\n}\r\n</style>\r\n"]}]}