AACA,QAAA,OAAA,CAAA,GAAA,CAAA,kBAAA,EAAA,MAAA,CAAA,QAAA;AACA,QAAA,OAAA,CAAA,GAAA,CAAA,oBAAA,EAAA,MAAA,CAAA,UAAA;AACA,QAAA,OAAA,CAAA,GAAA,CAAA,kBAAA,EAAA,MAAA,CAAA,QAAA;AACA,QAAA,OAAA,CAAA,GAAA,CAAA,gBAAA,EAAA,MAAA,CAAA,MAAA;AACA,QAAA,OAAA,CAAA,GAAA,CAAA,kCAAA,EAxBA,CA0BA;;AACA,cAAA,eAAA,GAAA;AACA,UAAA,QAAA,EAAA,KAAA,CAAA,OAAA,CAAA,MAAA,CAAA,QAAA,IAAA,MAAA,CAAA,QAAA,GAAA,EADA;AAEA,UAAA,UAAA,EAAA,MAAA,CAAA,UAAA,IAAA,EAFA;AAGA,UAAA,QAAA,EAAA,MAAA,CAAA,QAAA,IAAA,IAHA;AAIA,UAAA,iBAAA,EAAA,OAAA,CAAA,MAAA,CAAA,iBAAA,CAJA;AAKA,UAAA,MAAA,EAAA,KAAA,CAAA,OAAA,CAAA,MAAA,CAAA,MAAA,IAAA,MAAA,CAAA,MAAA,GAAA,MAAA,CAAA,MAAA,IAAA,EALA;AAMA,UAAA,SAAA,EAAA,MAAA,CAAA,SAAA,IAAA,EANA;AAOA,UAAA,SAAA,EAAA,MAAA,CAAA,SAAA,IAAA,EAPA;AAQA,UAAA,kBAAA,EAAA,KAAA,CAAA,OAAA,CAAA,MAAA,CAAA,kBAAA,IAAA,MAAA,CAAA,kBAAA,GAAA;AARA,SAAA;AAWA,QAAA,OAAA,CAAA,GAAA,CAAA,gCAAA;AACA,QAAA,OAAA,CAAA,GAAA,CAAA,qBAAA,EAAA,eAAA;AACA,QAAA,OAAA,CAAA,GAAA,CAAA,eAAA,EAAA,KAAA,YAAA,CAAA,eAAA,CAAA;AACA,QAAA,OAAA,CAAA,GAAA,CAAA,kCAAA,EAzCA,CA2CA;;AACA,aAAA,QAAA,CAAA,IAAA,CAAA;AACA,UAAA,IAAA,EAAA,WADA;AAEA,UAAA,OAAA,EAAA,eAAA,CAAA,MAFA;AAGA,UAAA,eAAA,EAAA,eAHA;AAIA,UAAA,IAAA,EAAA,IAAA,IAAA;AAJA,SAAA,EA5CA,CAmDA;;AACA,aAAA,SAAA,GAAA,MAAA,CAAA,MAAA,CAAA,SAAA,IAAA,EAAA,CAAA,CApDA,CAsDA;;AACA,aAAA,SAAA,CAAA,MAAA;AACA,eAAA,cAAA;AACA,SAFA,EAvDA,CA2DA;;AACA,YAAA,CAAA,KAAA,QAAA,EAAA;AACA,eAAA,WAAA;AACA;AAEA,OAhEA,CAgEA,OAAA,KAAA,EAAA;AACA,QAAA,OAAA,CAAA,KAAA,CAAA,SAAA,EAAA,KAAA,EADA,CAGA;;AACA,YAAA,KAAA,CAAA,QAAA,EAAA;AACA,UAAA,OAAA,CAAA,KAAA,CAAA,OAAA,EAAA,KAAA,CAAA,QAAA,CAAA,IAAA;AACA,UAAA,OAAA,CAAA,KAAA,CAAA,QAAA,EAAA,KAAA,CAAA,QAAA,CAAA,MAAA;AACA;;AAEA,aAAA,QAAA,CAAA,KAAA,CAAA,cAAA;AACA,OA1EA,SA0EA;AACA,aAAA,OAAA,GAAA,KAAA;AACA;AACA,KArLA;;AAwLA;AACA;AACA;;AACA;AACA;AACA;;AACA;AACA;AACA;AACA,UAAA,YAAA,GAAA;AACA,UAAA;AACA;AACA,cAAA,MAAA,GAAA,MAAA,aAAA,EAAA;AAEA,QAAA,OAAA,CAAA,GAAA,CAAA,6BAAA;AACA,QAAA,OAAA,CAAA,GAAA,CAAA,YAAA,EAAA,MAAA;AACA,QAAA,OAAA,CAAA,GAAA,CAAA,YAAA,EAAA,OAAA,MAAA;AACA,QAAA,OAAA,CAAA,GAAA,CAAA,kCAAA,EAPA,CASA;;AACA,YAAA,SAAA,GAAA,MAAA,CAVA,CAYA;;AACA,YAAA,OAAA,SAAA,KAAA,QAAA,IAAA,SAAA,KAAA,IAAA,EAAA;AACA,UAAA,OAAA,CAAA,GAAA,CAAA,sBAAA;AACA,UAAA,OAAA,CAAA,GAAA,CAAA,eAAA,EAAA,MAAA,CAAA,IAAA,CAAA,SAAA,CAAA;AAEA,UAAA,SAAA,GAAA,SAAA,CAAA,SAAA,IAAA,SAAA,CAAA,UAAA,IAAA,SAAA,CAAA,EAAA,IAAA,SAAA,CAAA,IAAA,IAAA,EAAA;AACA,SAlBA,CAoBA;;;AACA,aAAA,SAAA,GAAA,MAAA,CAAA,SAAA,IAAA,EAAA,CAAA;AAEA,QAAA,OAAA,CAAA,GAAA,CAAA,gBAAA,EAAA,KAAA,SAAA;AAEA,aAAA,QAAA,GAAA,EAAA;AACA,aAAA,WAAA,GAAA,CAAA;AACA,aAAA,QAAA,CAAA,OAAA,CAAA,QAAA;AACA,OA5BA,CA4BA,OAAA,KAAA,EAAA;AACA,QAAA,OAAA,CAAA,KAAA,CAAA,SAAA,EAAA,KAAA;AACA,aAAA,SAAA,GAAA,KAAA,iBAAA,EAAA;AACA,QAAA,OAAA,CAAA,GAAA,CAAA,WAAA,EAAA,KAAA,SAAA;AACA;AACA,KAnOA;;AAqOA;AACA;AACA;AACA,IAAA,iBAAA,GAAA;AACA,aAAA,IAAA,CAAA,GAAA,GAAA,QAAA,CAAA,EAAA,IAAA,IAAA,CAAA,MAAA,GAAA,QAAA,CAAA,EAAA,EAAA,MAAA,CAAA,CAAA,CAAA;AACA,KA1OA;;AA4OA;AACA;AACA;AACA,IAAA,WAAA,GAAA;AACA,WAAA,WAAA,GAAA,CAAA;AACA,KAjPA;;AAmPA;AACA;AACA;AACA,IAAA,cAAA,GAAA;AACA,YAAA,SAAA,GAAA,KAAA,KAAA,CAAA,WAAA;;AACA,UAAA,SAAA,EAAA;AACA,QAAA,SAAA,CAAA,SAAA,GAAA,SAAA,CAAA,YAAA;AACA;AACA,KA3PA;;AA6PA;AACA;AACA;;AACA;AACA;AACA;AACA,IAAA,cAAA,CAAA,MAAA,EAAA;AACA,WAAA,KAAA,CAAA,aAAA,EAAA,MAAA;AAEA,MAAA,OAAA,CAAA,GAAA,CAAA,wBAAA,EAAA,MAAA,CAAA,SAAA;AACA,WAAA,OAAA,CAAA,IAAA,CAAA;AACA,QAAA,IAAA,EAAA,cADA;AAEA,QAAA,KAAA,EAAA;AACA,UAAA,SAAA,EAAA,MAAA,CAAA;AADA;AAFA,OAAA;AAMA,KA7QA;;AAgRA;AACA;AACA;;AACA;AACA;AACA;;AACA;AACA;AACA;AACA,IAAA,qBAAA,CAAA,MAAA,EAAA;AACA,WAAA,KAAA,CAAA,kBAAA,EAAA,MAAA;AAEA,MAAA,OAAA,CAAA,GAAA,CAAA,aAAA,EAAA,MAAA,CAAA,UAAA,EAHA,CAKA;;AACA,WAAA,OAAA,CAAA,IAAA,CAAA;AACA,QAAA,IAAA,EAAA,eADA;AAEA,QAAA,KAAA,EAAA;AACA,UAAA,UAAA,EAAA,MAAA,CAAA;AADA;AAFA,OAAA;AAMA,KArSA;;AAwSA;AACA;AACA;AACA,IAAA,kBAAA,CAAA,QAAA,EAAA;AACA,YAAA,OAAA,GAAA;AACA,cAAA,SADA;AAEA,cAAA,SAFA;AAGA,cAAA,QAHA;AAIA,cAAA;AAJA,OAAA;AAMA,aAAA,OAAA,CAAA,QAAA,CAAA,IAAA,MAAA;AACA;;AAnTA;AAnBA,CAAA","sourcesContent":["<template>\r\n  <div class=\"chat-bot-container\">\r\n    <!-- 机器人按钮 -->\r\n    <div class=\"chat-bot-button\" @click=\"toggleChat\">\r\n      <i v-if=\"!showChat\" class=\"el-icon-service\"></i>\r\n      <i v-else class=\"el-icon-close\"></i>\r\n      <span v-if=\"!showChat && unreadCount > 0\" class=\"badge\">{{ unreadCount }}</span>\r\n    </div>\r\n\r\n    <!-- 聊天窗口 -->\r\n    <transition name=\"slide-fade\">\r\n      <div v-if=\"showChat\" class=\"chat-window\">\r\n        <!-- 窗口头部 -->\r\n        <div class=\"chat-header\">\r\n          <div class=\"header-left\">\r\n            <i class=\"el-icon-service\"></i>\r\n            <span>AI医疗助手</span>\r\n          </div>\r\n          <div class=\"header-right\">\r\n            <el-button type=\"text\" size=\"mini\" @click=\"toggleChat\" icon=\"el-icon-minus\">\r\n              最小化\r\n            </el-button>\r\n            <el-button type=\"text\" size=\"mini\" @click=\"startNewChat\" icon=\"el-icon-refresh\">\r\n              新对话\r\n            </el-button>\r\n          </div>\r\n        </div>\r\n\r\n        <!-- 消息列表 -->\r\n        <div class=\"chat-message-list\" ref=\"messageList\">\r\n          <div\r\n              v-for=\"(message, index) in messages\"\r\n              :key=\"index\"\r\n              :class=\"['chat-message-item', message.role]\"\r\n          >\r\n            <!-- 用户消息 -->\r\n            <div v-if=\"message.role === 'user'\" class=\"user-message\">\r\n              <div class=\"chat-avatar user-avatar\">\r\n                <i class=\"el-icon-user\"></i>\r\n              </div>\r\n              <div class=\"chat-message-content user-content\">\r\n                {{ message.content }}\r\n              </div>\r\n            </div>\r\n\r\n            <!-- AI消息 -->\r\n            <div v-else class=\"assistant-message\">\r\n              <div class=\"chat-avatar assistant-avatar\">\r\n                <i class=\"el-icon-service\"></i>\r\n              </div>\r\n              <div class=\"chat-message-content assistant-content\">\r\n                <!-- 诊断结果卡片 -->\r\n                <div v-if=\"message.diagnosisResult && hasValidData(message.diagnosisResult)\" class=\"mini-diagnosis-result\">\r\n                  <div class=\"result-header\">\r\n                    <i class=\"el-icon-s-claim\"></i>\r\n                    <span>诊断结果</span>\r\n                  </div>\r\n                  <div class=\"result-content\">\r\n                    <!-- 可能疾病 -->\r\n                    <div class=\"result-item\">\r\n                      <div class=\"result-label\">可能疾病</div>\r\n                      <div class=\"result-value diseases-list\">\r\n                        <el-tag\r\n                            v-for=\"(disease, idx) in message.diagnosisResult.diseases\"\r\n                            :key=\"idx\"\r\n                            size=\"mini\"\r\n                            type=\"info\"\r\n                            effect=\"plain\"\r\n                        >\r\n                          {{ disease }}\r\n                        </el-tag>\r\n                      </div>\r\n                    </div>\r\n\r\n                    <!-- 推荐科室 -->\r\n                    <div class=\"result-item\">\r\n                      <div class=\"result-label\">推荐科室</div>\r\n                      <div class=\"result-value\">\r\n                        <el-tag size=\"small\" type=\"primary\">{{ message.diagnosisResult.department || '暂无' }}</el-tag>\r\n                      </div>\r\n                    </div>\r\n\r\n                    <!-- 严重程度 -->\r\n                    <div class=\"result-item\">\r\n                      <div class=\"result-label\">严重程度</div>\r\n                      <div class=\"result-value\">\r\n                        <el-tag :type=\"getSeverityTagType(message.diagnosisResult.severity)\" size=\"small\">\r\n                          {{ message.diagnosisResult.severity || '未知' }}\r\n                        </el-tag>\r\n                      </div>\r\n                    </div>\r\n\r\n                    <!-- 就医建议 -->\r\n                    <div class=\"result-item\">\r\n                      <div class=\"result-label\">就医建议</div>\r\n                      <div class=\"result-value advice-content\">\r\n                        <pre>{{ formatAdvice(message.diagnosisResult.advice) }}</pre>\r\n                      </div>\r\n                    </div>\r\n                  </div>\r\n\r\n                  <!-- 操作按钮 -->\r\n                  <div class=\"result-actions\">\r\n                    <el-button size=\"mini\" type=\"primary\" icon=\"el-icon-view\" @click=\"showFullResult(message.diagnosisResult)\">\r\n                      查看详情\r\n                    </el-button>\r\n                    <el-button size=\"mini\" type=\"success\" icon=\"el-icon-date\" @click=\"handleMakeAppointment(message.diagnosisResult)\">\r\n                      立即预约\r\n                    </el-button>\r\n                  </div>\r\n                </div>\r\n\r\n                <!-- 普通文本消息 -->\r\n                <div v-else class=\"text-content\">\r\n                  {{ message.content || '暂无回复' }}\r\n                </div>\r\n              </div>\r\n            </div>\r\n          </div>\r\n\r\n          <!-- 加载动画 -->\r\n          <div v-if=\"loading\" class=\"chat-message-item assistant-message\">\r\n            <div class=\"chat-avatar assistant-avatar\">\r\n              <i class=\"el-icon-service\"></i>\r\n            </div>\r\n            <div class=\"chat-message-content assistant-content\">\r\n              <div class=\"loading-dots\">\r\n                <span></span>\r\n                <span></span>\r\n                <span></span>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n\r\n        <!-- 输入区域 -->\r\n        <div class=\"chat-input-area\">\r\n          <el-input\r\n              v-model=\"inputText\"\r\n              type=\"textarea\"\r\n              :rows=\"2\"\r\n              placeholder=\"描述您的症状...\"\r\n              @keyup.ctrl.enter.native=\"sendMessage\"\r\n              @focus=\"clearUnread\"\r\n              resize=\"none\"\r\n          />\r\n          <div class=\"input-actions\">\r\n            <span class=\"input-tip\">按 Ctrl + Enter 发送</span>\r\n            <el-button\r\n                type=\"primary\"\r\n                size=\"small\"\r\n                :loading=\"loading\"\r\n                :disabled=\"!inputText.trim()\"\r\n                @click=\"sendMessage\"\r\n                icon=\"el-icon-s-promotion\"\r\n            >\r\n              发送\r\n            </el-button>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </transition>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport { diagnosisWithChat, createSession } from '@/api/aiApi'\r\nimport { getToken } from '@/utils/storage.js'\r\nimport jwtDecode from 'jwt-decode'\r\n\r\nexport default {\r\n  name: 'ChatBot',\r\n  data() {\r\n    return {\r\n      showChat: false,\r\n      messages: [],\r\n      inputText: '',\r\n      loading: false,\r\n      sessionId: '',\r\n      patientId: null,\r\n      unreadCount: 0\r\n    }\r\n  },\r\n  created() {\r\n    // 从 Token 获取患者ID\r\n    this.initPatientId()\r\n    // 创建新会话\r\n    this.startNewChat()\r\n  },\r\n  methods: {\r\n    /**\r\n     * 检查是否有有效数据\r\n     */\r\n    hasValidData(diagnosisResult) {\r\n      return diagnosisResult &&\r\n          (diagnosisResult.diseases ||\r\n              diagnosisResult.department ||\r\n              diagnosisResult.severity ||\r\n              diagnosisResult.advice)\r\n    },\r\n\r\n    /**\r\n     * 格式化建议内容\r\n     */\r\n    formatAdvice(advice) {\r\n      if (!advice) return '暂无建议'\r\n\r\n      // 如果是数组，转换为字符串\r\n      if (Array.isArray(advice)) {\r\n        return advice.join('\\n')\r\n      }\r\n\r\n      // 如果是字符串，直接返回\r\n      return advice\r\n    },\r\n\r\n    /**\r\n     * 初始化患者ID\r\n     */\r\n    initPatientId() {\r\n      try {\r\n        // 方法1：从 sessionStorage 获取 Token\r\n        let token = getToken()\r\n        console.log('Token (sessionStorage):', token)\r\n\r\n        // 方法2：如果 sessionStorage 没有，尝试 localStorage\r\n        if (!token) {\r\n          token = localStorage.getItem('token')\r\n          console.log('Token (localStorage):', token)\r\n        }\r\n\r\n        if (token) {\r\n          const tokenData = jwtDecode(token)\r\n          console.log('Token 数据:', tokenData)\r\n\r\n          if (tokenData && tokenData.pId) {\r\n            this.patientId = tokenData.pId\r\n            console.log('从 Token 获取患者ID:', this.patientId)\r\n            return\r\n          } else {\r\n            console.log('Token 中没有 pId 字段')\r\n            console.log('Token 中的字段:', Object.keys(tokenData))\r\n          }\r\n        } else {\r\n          console.log('Token 为空')\r\n        }\r\n\r\n        // 如果获取失败，提示用户\r\n        if (!this.patientId) {\r\n          console.warn('未获取到患者ID')\r\n          this.$message.warning('请先登录')\r\n        }\r\n\r\n      } catch (error) {\r\n        console.error('获取患者ID失败:', error)\r\n        this.$message.error('获取用户信息失败')\r\n      }\r\n    },\r\n\r\n    /**\r\n     * 切换聊天窗口\r\n     */\r\n    toggleChat() {\r\n      this.showChat = !this.showChat\r\n      if (this.showChat) {\r\n        this.clearUnread()\r\n      }\r\n    },\r\n\r\n    /**\r\n     * 发送消息\r\n     */\r\n    async sendMessage() {\r\n      const text = this.inputText.trim()\r\n      if (!text) return\r\n\r\n      // 检查患者ID\r\n      if (!this.patientId) {\r\n        this.$message.warning('请先登录')\r\n        return\r\n      }\r\n\r\n      // 添加用户消息\r\n      this.messages.push({\r\n        role: 'user',\r\n        content: text,\r\n        time: new Date()\r\n      })\r\n\r\n      // 清空输入框\r\n      this.inputText = ''\r\n      this.loading = true\r\n\r\n      try {\r\n        // 构建请求参数，确保所有值都是字符串\r\n        const requestData = {\r\n          sessionId: String(this.sessionId || ''),\r\n          symptoms: String(text),\r\n          patientId: String(this.patientId)\r\n        }\r\n\r\n        console.log('========== 请求参数 ==========')\r\n        console.log('sessionId:', requestData.sessionId)\r\n        console.log('symptoms:', requestData.symptoms)\r\n        console.log('patientId:', requestData.patientId)\r\n        console.log('================================')\r\n\r\n        // 调用AI诊断接口\r\n        const result = await diagnosisWithChat(requestData)\r\n\r\n        console.log('========== AI 返回结果 ==========')\r\n        console.log('完整 result:', result)\r\n        console.log('result 类型:', typeof result)\r\n        console.log('result.diseases:', result.diseases)\r\n        console.log('result.department:', result.department)\r\n        console.log('result.severity:', result.severity)\r\n        console.log('result.advice:', result.advice)\r\n        console.log('================================')\r\n\r\n        // 确保返回的数据格式正确\r\n        const diagnosisResult = {\r\n          diseases: Array.isArray(result.diseases) ? result.diseases : [],\r\n          department: result.department || '',\r\n          severity: result.severity || '未知',\r\n          needImmediateCare: Boolean(result.needImmediateCare),\r\n          advice: Array.isArray(result.advice) ? result.advice : (result.advice || ''),\r\n          reasoning: result.reasoning || '',\r\n          sessionId: result.sessionId || '',\r\n          recommendedDoctors: Array.isArray(result.recommendedDoctors) ? result.recommendedDoctors : []\r\n        }\r\n\r\n        console.log('========== 处理后的诊断结果 ==========')\r\n        console.log('完整 diagnosisResult:', diagnosisResult)\r\n        console.log('hasValidData:', this.hasValidData(diagnosisResult))\r\n        console.log('================================')\r\n\r\n        // 添加AI消息\r\n        this.messages.push({\r\n          role: 'assistant',\r\n          content: diagnosisResult.advice,\r\n          diagnosisResult: diagnosisResult,\r\n          time: new Date()\r\n        })\r\n\r\n        // 更新会话ID\r\n        this.sessionId = String(result.sessionId || '')\r\n\r\n        // 滚动到底部\r\n        this.$nextTick(() => {\r\n          this.scrollToBottom()\r\n        })\r\n\r\n        // 如果窗口最小化，增加未读数\r\n        if (!this.showChat) {\r\n          this.unreadCount++\r\n        }\r\n\r\n      } catch (error) {\r\n        console.error('AI分析失败:', error)\r\n\r\n        // 打印详细错误信息\r\n        if (error.response) {\r\n          console.error('错误响应:', error.response.data)\r\n          console.error('错误状态码:', error.response.status)\r\n        }\r\n\r\n        this.$message.error('AI分析失败，请稍后重试')\r\n      } finally {\r\n        this.loading = false\r\n      }\r\n    },\r\n\r\n\r\n    /**\r\n     * 开始新对话\r\n     */\r\n    /**\r\n     * 开始新对话\r\n     */\r\n    /**\r\n     * 开始新对话\r\n     */\r\n    async startNewChat() {\r\n      try {\r\n        // 创建新会话\r\n        const result = await createSession()\r\n\r\n        console.log('========== 创建新会话 ==========')\r\n        console.log('完整 result:', result)\r\n        console.log('result 类型:', typeof result)\r\n        console.log('================================')\r\n\r\n        // 确保 sessionId 是字符串\r\n        let sessionId = result\r\n\r\n        // 如果是对象，尝试提取其中的字段\r\n        if (typeof sessionId === 'object' && sessionId !== null) {\r\n          console.log('sessionId 是对象，尝试提取字段')\r\n          console.log('sessionId 的键:', Object.keys(sessionId))\r\n\r\n          sessionId = sessionId.sessionId || sessionId.session_id || sessionId.id || sessionId.data || ''\r\n        }\r\n\r\n        // 转换为字符串\r\n        this.sessionId = String(sessionId || '')\r\n\r\n        console.log('最终的 sessionId:', this.sessionId)\r\n\r\n        this.messages = []\r\n        this.unreadCount = 0\r\n        this.$message.success('新会话已创建')\r\n      } catch (error) {\r\n        console.error('创建会话失败:', error)\r\n        this.sessionId = this.generateSessionId()\r\n        console.log('使用临时会话ID:', this.sessionId)\r\n      }\r\n    },\r\n\r\n    /**\r\n     * 生成临时会话ID\r\n     */\r\n    generateSessionId() {\r\n      return Date.now().toString(36) + Math.random().toString(36).substr(2)\r\n    },\r\n\r\n    /**\r\n     * 清除未读\r\n     */\r\n    clearUnread() {\r\n      this.unreadCount = 0\r\n    },\r\n\r\n    /**\r\n     * 滚动到底部\r\n     */\r\n    scrollToBottom() {\r\n      const container = this.$refs.messageList\r\n      if (container) {\r\n        container.scrollTop = container.scrollHeight\r\n      }\r\n    },\r\n\r\n    /**\r\n     * 显示完整结果\r\n     */\r\n    /**\r\n     * 显示完整结果\r\n     */\r\n    showFullResult(result) {\r\n      this.$emit('show-result', result)\r\n\r\n      console.log('跳转到 AI 诊断页面，sessionId:', result.sessionId)\r\n      this.$router.push({\r\n        path: '/aiDiagnosis',\r\n        query: {\r\n          sessionId: result.sessionId\r\n        }\r\n      })\r\n    },\r\n\r\n\r\n    /**\r\n     * 处理预约医生\r\n     */\r\n    /**\r\n     * 处理预约医生\r\n     */\r\n    /**\r\n     * 处理预约医生\r\n     */\r\n    handleMakeAppointment(result) {\r\n      this.$emit('make-appointment', result)\r\n\r\n      console.log('跳转到预约页面，科室:', result.department)\r\n\r\n      // 使用 path 而不是 name\r\n      this.$router.push({\r\n        path: '/orderOperate',\r\n        query: {\r\n          department: result.department\r\n        }\r\n      })\r\n    },\r\n\r\n\r\n    /**\r\n     * 获取严重程度标签类型\r\n     */\r\n    getSeverityTagType(severity) {\r\n      const typeMap = {\r\n        '轻微': 'success',\r\n        '中等': 'warning',\r\n        '严重': 'danger',\r\n        '紧急': 'danger'\r\n      }\r\n      return typeMap[severity] || 'info'\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n/* 容器 */\r\n.chat-bot-container {\r\n  position: fixed;\r\n  bottom: 30px;\r\n  right: 30px;\r\n  z-index: 9999;\r\n}\r\n\r\n/* 机器人按钮 */\r\n.chat-bot-button {\r\n  width: 60px;\r\n  height: 60px;\r\n  border-radius: 50%;\r\n  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);\r\n  color: #fff;\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  font-size: 28px;\r\n  cursor: pointer;\r\n  box-shadow: 0 4px 12px rgba(102, 126, 234, 0.4);\r\n  transition: all 0.3s ease;\r\n  position: relative;\r\n}\r\n\r\n.chat-bot-button:hover {\r\n  transform: scale(1.1) rotate(5deg);\r\n  box-shadow: 0 6px 20px rgba(102, 126, 234, 0.6);\r\n}\r\n\r\n.chat-bot-button:active {\r\n  transform: scale(0.95);\r\n}\r\n\r\n.badge {\r\n  position: absolute;\r\n  top: -5px;\r\n  right: -5px;\r\n  min-width: 20px;\r\n  height: 20px;\r\n  padding: 0 6px;\r\n  background: #f56c6c;\r\n  color: #fff;\r\n  border-radius: 10px;\r\n  font-size: 12px;\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  border: 2px solid #fff;\r\n  font-weight: bold;\r\n  box-shadow: 0 2px 8px rgba(245, 108, 108, 0.4);\r\n}\r\n\r\n/* 聊天窗口 */\r\n.chat-window {\r\n  position: absolute;\r\n  bottom: 80px;\r\n  right: 0;\r\n  width: 480px;\r\n  max-height: 650px;\r\n  background: #fff;\r\n  border-radius: 16px;\r\n  box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);\r\n  display: flex;\r\n  flex-direction: column;\r\n  overflow: hidden;\r\n}\r\n\r\n/* 动画 */\r\n.slide-fade-enter-active {\r\n  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);\r\n}\r\n\r\n.slide-fade-leave-active {\r\n  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);\r\n}\r\n\r\n.slide-fade-enter {\r\n  transform: translateY(20px) scale(0.95);\r\n  opacity: 0;\r\n}\r\n\r\n.slide-fade-leave-to {\r\n  transform: translateY(20px) scale(0.95);\r\n  opacity: 0;\r\n}\r\n\r\n/* 头部 */\r\n.chat-header {\r\n  padding: 16px 20px;\r\n  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);\r\n  color: #fff;\r\n  display: flex;\r\n  justify-content: space-between;\r\n  align-items: center;\r\n  box-shadow: 0 2px 8px rgba(102, 126, 234, 0.3);\r\n}\r\n\r\n.header-left {\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 12px;\r\n  font-size: 16px;\r\n  font-weight: 600;\r\n}\r\n\r\n.header-right {\r\n  display: flex;\r\n  gap: 8px;\r\n}\r\n\r\n.header-right .el-button {\r\n  color: #fff;\r\n  padding: 8px 12px;\r\n  font-size: 14px;\r\n  border: none;\r\n  background: rgba(255, 255, 255, 0.1);\r\n}\r\n\r\n.header-right .el-button:hover {\r\n  background: rgba(255, 255, 255, 0.25);\r\n  transform: scale(1.05);\r\n}\r\n\r\n/* 消息列表 */\r\n.chat-message-list {\r\n  flex: 1;\r\n  overflow-y: auto;\r\n  padding: 20px;\r\n  background: linear-gradient(180deg, #f8f9fa 0%, #f0f2f5 100%);\r\n}\r\n\r\n.chat-message-item {\r\n  margin-bottom: 20px;\r\n  display: flex;\r\n  align-items: flex-start;\r\n  animation: fadeIn 0.3s ease;\r\n}\r\n\r\n@keyframes fadeIn {\r\n  from {\r\n    opacity: 0;\r\n    transform: translateY(10px);\r\n  }\r\n  to {\r\n    opacity: 1;\r\n    transform: translateY(0);\r\n  }\r\n}\r\n\r\n.user-message {\r\n  justify-content: flex-end;\r\n}\r\n\r\n.assistant-message {\r\n  justify-content: flex-start;\r\n}\r\n\r\n/* 头像 */\r\n.chat-avatar {\r\n  width: 40px;\r\n  height: 40px;\r\n  border-radius: 50%;\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  font-size: 20px;\r\n  flex-shrink: 0;\r\n  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);\r\n  transition: transform 0.2s;\r\n}\r\n\r\n.chat-avatar:hover {\r\n  transform: scale(1.1);\r\n}\r\n\r\n.user-avatar {\r\n  background: linear-gradient(135deg, #409EFF 0%, #53a8ff 100%);\r\n  color: #fff;\r\n  margin-left: 12px;\r\n}\r\n\r\n.assistant-avatar {\r\n  background: linear-gradient(135deg, #67C23A 0%, #85ce61 100%);\r\n  color: #fff;\r\n  margin-right: 12px;\r\n}\r\n\r\n/* 消息内容 */\r\n.chat-message-content {\r\n  max-width: 70%;\r\n  padding: 14px 18px;\r\n  border-radius: 16px;\r\n  word-wrap: break-word;\r\n  font-size: 14px;\r\n  line-height: 1.6;\r\n  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);\r\n}\r\n\r\n.user-content {\r\n  background: linear-gradient(135deg, #409EFF 0%, #53a8ff 100%);\r\n  color: #fff;\r\n  border-bottom-right-radius: 4px;\r\n}\r\n\r\n.assistant-content {\r\n  background: #fff;\r\n  color: #333;\r\n  border-bottom-left-radius: 4px;\r\n}\r\n\r\n/* 普通文本 */\r\n.text-content {\r\n  white-space: pre-wrap;\r\n  word-wrap: break-word;\r\n}\r\n\r\n/* 诊断结果卡片 */\r\n.mini-diagnosis-result {\r\n  background: linear-gradient(135deg, #e3f2fd 0%, #bbdefb 100%);\r\n  border-left: 4px solid #2196F3;\r\n  border-radius: 12px;\r\n  padding: 16px;\r\n  box-shadow: 0 2px 8px rgba(33, 150, 243, 0.15);\r\n}\r\n\r\n.result-header {\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 8px;\r\n  font-weight: 600;\r\n  color: #1976D2;\r\n  margin-bottom: 16px;\r\n  font-size: 15px;\r\n  padding-bottom: 12px;\r\n  border-bottom: 1px solid rgba(33, 150, 243, 0.2);\r\n}\r\n\r\n.result-header i {\r\n  font-size: 18px;\r\n}\r\n\r\n.result-content {\r\n  display: flex;\r\n  flex-direction: column;\r\n  gap: 12px;\r\n}\r\n\r\n.result-item {\r\n  display: flex;\r\n  flex-direction: column;\r\n  gap: 6px;\r\n}\r\n\r\n.result-label {\r\n  font-size: 13px;\r\n  color: #666;\r\n  font-weight: 500;\r\n}\r\n\r\n.result-value {\r\n  font-size: 14px;\r\n  color: #333;\r\n}\r\n\r\n/* 疾病列表 */\r\n.diseases-list {\r\n  display: flex;\r\n  flex-wrap: wrap;\r\n  gap: 8px;\r\n}\r\n\r\n/* 建议内容 */\r\n.advice-content pre {\r\n  margin: 0;\r\n  font-family: inherit;\r\n  font-size: 13px;\r\n  line-height: 1.8;\r\n  color: #333;\r\n  white-space: pre-wrap;\r\n  word-wrap: break-word;\r\n}\r\n\r\n/* 操作按钮 */\r\n.result-actions {\r\n  display: flex;\r\n  gap: 12px;\r\n  margin-top: 16px;\r\n  padding-top: 12px;\r\n  border-top: 1px solid rgba(33, 150, 243, 0.2);\r\n}\r\n\r\n.result-actions .el-button {\r\n  flex: 1;\r\n  border-radius: 8px;\r\n  font-weight: 500;\r\n}\r\n\r\n/* 加载动画 */\r\n.loading-dots {\r\n  display: flex;\r\n  gap: 4px;\r\n  align-items: center;\r\n  padding: 8px 0;\r\n}\r\n\r\n.loading-dots span {\r\n  width: 8px;\r\n  height: 8px;\r\n  border-radius: 50%;\r\n  background: #67C23A;\r\n  animation: bounce 1.4s infinite ease-in-out both;\r\n}\r\n\r\n.loading-dots span:nth-child(1) {\r\n  animation-delay: -0.32s;\r\n}\r\n\r\n.loading-dots span:nth-child(2) {\r\n  animation-delay: -0.16s;\r\n}\r\n\r\n@keyframes bounce {\r\n  0%, 80%, 100% {\r\n    transform: scale(0);\r\n    opacity: 0.5;\r\n  }\r\n  40% {\r\n    transform: scale(1);\r\n    opacity: 1;\r\n  }\r\n}\r\n\r\n/* 输入区域 */\r\n.chat-input-area {\r\n  padding: 16px 20px;\r\n  border-top: 1px solid #e4e7ed;\r\n  background: #fff;\r\n}\r\n\r\n.chat-input-area .el-textarea__inner {\r\n  border-radius: 8px;\r\n  border: 2px solid #e4e7ed;\r\n  transition: all 0.3s;\r\n}\r\n\r\n.chat-input-area .el-textarea__inner:focus {\r\n  border-color: #667eea;\r\n  box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);\r\n}\r\n\r\n.input-actions {\r\n  display: flex;\r\n  justify-content: space-between;\r\n  align-items: center;\r\n  margin-top: 12px;\r\n}\r\n\r\n.input-tip {\r\n  font-size: 12px;\r\n  color: #909399;\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 4px;\r\n}\r\n\r\n.input-tip::before {\r\n  content: '⌨️';\r\n}\r\n\r\n/* 滚动条样式 */\r\n.chat-message-list::-webkit-scrollbar {\r\n  width: 6px;\r\n}\r\n\r\n.chat-message-list::-webkit-scrollbar-track {\r\n  background: #f1f1f1;\r\n  border-radius: 3px;\r\n}\r\n\r\n.chat-message-list::-webkit-scrollbar-thumb {\r\n  background: linear-gradient(180deg, #c1c1c1 0%, #a8a8a8 100%);\r\n  border-radius: 3px;\r\n}\r\n\r\n.chat-message-list::-webkit-scrollbar-thumb:hover {\r\n  background: linear-gradient(180deg, #a8a8a8 0%, #8f8f8f 100%);\r\n}\r\n\r\n/* 响应式设计 */\r\n@media screen and (max-width: 768px) {\r\n  .chat-bot-container {\r\n    bottom: 20px;\r\n    right: 20px;\r\n  }\r\n\r\n  .chat-window {\r\n    width: calc(100vw - 40px);\r\n    max-width: 400px;\r\n    right: -20px;\r\n    bottom: 90px;\r\n    max-height: 70vh;\r\n  }\r\n\r\n  .chat-message-content {\r\n    max-width: 80%;\r\n  }\r\n}\r\n</style>\r\n"],"sourceRoot":"src/components"}]}