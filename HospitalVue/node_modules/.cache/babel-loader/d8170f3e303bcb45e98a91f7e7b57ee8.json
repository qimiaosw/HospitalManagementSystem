AAyCA,UAAA,aAAA,CAAA,MAAA,EAAA;AACA,UAAA;AACA,cAAA,QAAA,GAAA,MAAA,KAAA,MAAA,CAAA,IAAA,CAAA,qBAAA,EAAA;AACA,UAAA,UAAA,EAAA,MAAA,CAAA,YADA;AAEA,UAAA,OAAA,EAAA,MAAA,CAAA,QAFA;AAGA,UAAA,WAAA,EAAA,MAAA,CAAA,YAHA;AAIA,UAAA,SAAA,EAAA,MAAA,CAAA,SAJA;AAKA,UAAA,IAAA,EAAA,MAAA,CAAA;AALA,SAAA,CAAA;;AAQA,YAAA,QAAA,CAAA,IAAA,CAAA,OAAA,EAAA;AACA,eAAA,WAAA,GAAA;AACA,YAAA,OAAA,EAAA,IADA;AAEA,YAAA,UAAA,EAAA,MAAA,CAAA,YAFA;AAGA,YAAA,OAAA,EAAA,MAAA,CAAA,QAHA;AAIA,YAAA,WAAA,EAAA,MAAA,CAAA,YAJA;AAKA,YAAA,SAAA,EAAA,MAAA,CAAA,SAAA,IAAA,IAAA,IAAA,GAAA,cAAA,EALA;AAMA,eAAA,QAAA,CAAA,IAAA,CAAA;AANA,WAAA;AAQA,SATA,MASA;AACA,eAAA,WAAA,GAAA;AACA,YAAA,OAAA,EAAA,KADA;AAEA,YAAA,OAAA,EAAA,QAAA,CAAA,IAAA,CAAA,OAAA,IAAA,QAFA;AAGA,YAAA,UAAA,EAAA,MAAA,CAAA;AAHA,WAAA;AAKA;AACA,OAzBA,CAyBA,OAAA,KAAA,EAAA;AACA,QAAA,OAAA,CAAA,KAAA,CAAA,SAAA,EAAA,KAAA;AACA,aAAA,WAAA,GAAA;AACA,UAAA,OAAA,EAAA,KADA;AAEA,UAAA,OAAA,EAAA,cAFA;AAGA,UAAA,UAAA,EAAA,MAAA,CAAA;AAHA,SAAA;AAKA;AACA,KA3EA;;AA6EA,IAAA,eAAA,GAAA;AACA,UAAA,KAAA,WAAA,IAAA,KAAA,WAAA,CAAA,UAAA,EAAA;AACA,aAAA,OAAA,CAAA,IAAA,CAAA;AACA,UAAA,IAAA,EAAA,eADA;AAEA,UAAA,KAAA,EAAA;AAAA,YAAA,OAAA,EAAA,KAAA,WAAA,CAAA;AAAA;AAFA,SAAA;AAIA,OALA,MAKA;AACA,aAAA,OAAA,CAAA,IAAA,CAAA,SAAA;AACA;AACA,KAtFA;;AAwFA,IAAA,QAAA,GAAA;AACA,WAAA,OAAA,CAAA,IAAA,CAAA,GAAA;AACA,KA1FA;;AA4FA,IAAA,UAAA,GAAA;AACA,WAAA,OAAA,CAAA,IAAA,CAAA,SAAA;AACA,KA9FA;;AAgGA,IAAA,YAAA,GAAA;AACA,UAAA,KAAA,WAAA,IAAA,KAAA,WAAA,CAAA,UAAA,EAAA;AACA,aAAA,OAAA,CAAA,IAAA,CAAA;AACA,UAAA,IAAA,EAAA,UADA;AAEA,UAAA,KAAA,EAAA;AAAA,YAAA,OAAA,EAAA,KAAA,WAAA,CAAA;AAAA;AAFA,SAAA;AAIA,OALA,MAKA;AACA,aAAA,OAAA,CAAA,IAAA,CAAA,UAAA;AACA;AACA;;AAzGA;AAXA,CAAA","sourcesContent":["<template>\r\n  <div class=\"payment-callback\">\r\n    <div v-if=\"loading\" class=\"loading-container\">\r\n      <el-skeleton :rows=\"6\" animated />\r\n    </div>\r\n\r\n    <div v-else-if=\"paymentData\" class=\"result-container\">\r\n      <!-- 支付成功 -->\r\n      <div v-if=\"paymentData.success\" class=\"success-card\">\r\n        <div class=\"success-icon\">✓</div>\r\n        <h2>支付成功！</h2>\r\n\r\n        <div class=\"payment-info\">\r\n          <div class=\"info-item\">\r\n            <span class=\"label\">订单号：</span>\r\n            <span class=\"value\">{{ paymentData.outTradeNo }}</span>\r\n          </div>\r\n          <div class=\"info-item\">\r\n            <span class=\"label\">支付宝交易号：</span>\r\n            <span class=\"value\">{{ paymentData.tradeNo }}</span>\r\n          </div>\r\n          <div class=\"info-item\">\r\n            <span class=\"label\">支付金额：</span>\r\n            <span class=\"value amount\">¥{{ paymentData.totalAmount }}</span>\r\n          </div>\r\n          <div class=\"info-item\">\r\n            <span class=\"label\">支付时间：</span>\r\n            <span class=\"value\">{{ paymentData.timestamp }}</span>\r\n          </div>\r\n        </div>\r\n\r\n        <div class=\"actions\">\r\n          <el-button type=\"primary\" @click=\"goToOrderDetail\">查看订单详情</el-button>\r\n          <el-button @click=\"goToHome\">返回首页</el-button>\r\n        </div>\r\n      </div>\r\n\r\n      <!-- 支付失败 -->\r\n      <div v-else class=\"error-card\">\r\n        <div class=\"error-icon\">✗</div>\r\n        <h2>支付处理失败</h2>\r\n        <p class=\"error-message\">{{ paymentData.message || '支付验证失败，请稍后重试' }}</p>\r\n\r\n        <div class=\"actions\">\r\n          <el-button type=\"primary\" @click=\"retryPayment\">重新支付</el-button>\r\n          <el-button @click=\"goToOrders\">查看订单</el-button>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: 'PaymentCallback',\r\n  data() {\r\n    return {\r\n      loading: true,\r\n      paymentData: null\r\n    };\r\n  },\r\n  mounted() {\r\n    this.handlePaymentCallback();\r\n  },\r\n  methods: {\r\n    async handlePaymentCallback() {\r\n      try {\r\n        // 1. 首先检查URL参数\r\n        const params = this.$route.query;\r\n\r\n        if (params.out_trade_no) {\r\n          console.log('从URL获取支付宝参数:', params);\r\n          await this.verifyPayment(params);\r\n          return;\r\n        }\r\n\r\n        // 2. 如果没有URL参数，检查sessionStorage\r\n        const storedParams = sessionStorage.getItem('alipayCallbackParams');\r\n        if (storedParams) {\r\n          const alipayParams = JSON.parse(storedParams);\r\n          console.log('从sessionStorage获取支付宝参数:', alipayParams);\r\n          await this.verifyPayment(alipayParams);\r\n\r\n          // 清理sessionStorage\r\n          sessionStorage.removeItem('alipayCallbackParams');\r\n          return;\r\n        }\r\n\r\n        // 3. 都没有找到参数，显示错误\r\n        this.paymentData = {\r\n          success: false,\r\n          message: '未找到支付信息'\r\n        };\r\n\r\n      } catch (error) {\r\n        console.error('支付回调处理失败:', error);\r\n        this.paymentData = {\r\n          success: false,\r\n          message: '处理支付结果时发生错误'\r\n        };\r\n      } finally {\r\n        this.loading = false;\r\n      }\r\n    },\r\n\r\n    async verifyPayment(params) {\r\n      try {\r\n        const response = await this.$axios.post('/api/payment/verify', {\r\n          outTradeNo: params.out_trade_no,\r\n          tradeNo: params.trade_no,\r\n          totalAmount: params.total_amount,\r\n          timestamp: params.timestamp,\r\n          sign: params.sign\r\n        });\r\n\r\n        if (response.data.success) {\r\n          this.paymentData = {\r\n            success: true,\r\n            outTradeNo: params.out_trade_no,\r\n            tradeNo: params.trade_no,\r\n            totalAmount: params.total_amount,\r\n            timestamp: params.timestamp || new Date().toLocaleString(),\r\n            ...response.data.data\r\n          };\r\n        } else {\r\n          this.paymentData = {\r\n            success: false,\r\n            message: response.data.message || '支付验证失败',\r\n            outTradeNo: params.out_trade_no\r\n          };\r\n        }\r\n      } catch (error) {\r\n        console.error('验证支付失败:', error);\r\n        this.paymentData = {\r\n          success: false,\r\n          message: '网络错误，请检查支付状态',\r\n          outTradeNo: params.out_trade_no\r\n        };\r\n      }\r\n    },\r\n\r\n    goToOrderDetail() {\r\n      if (this.paymentData && this.paymentData.outTradeNo) {\r\n        this.$router.push({\r\n          path: '/order/detail',\r\n          query: { orderNo: this.paymentData.outTradeNo }\r\n        });\r\n      } else {\r\n        this.$router.push('/orders');\r\n      }\r\n    },\r\n\r\n    goToHome() {\r\n      this.$router.push('/');\r\n    },\r\n\r\n    goToOrders() {\r\n      this.$router.push('/orders');\r\n    },\r\n\r\n    retryPayment() {\r\n      if (this.paymentData && this.paymentData.outTradeNo) {\r\n        this.$router.push({\r\n          path: '/payment',\r\n          query: { orderNo: this.paymentData.outTradeNo }\r\n        });\r\n      } else {\r\n        this.$router.push('/payment');\r\n      }\r\n    }\r\n  }\r\n};\r\n</script>\r\n\r\n<style scoped>\r\n.payment-callback {\r\n  min-height: 60vh;\r\n  display: flex;\r\n  justify-content: center;\r\n  align-items: center;\r\n  padding: 20px;\r\n}\r\n\r\n.loading-container {\r\n  width: 100%;\r\n  max-width: 600px;\r\n}\r\n\r\n.success-card,\r\n.error-card {\r\n  background: white;\r\n  border-radius: 12px;\r\n  padding: 40px;\r\n  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);\r\n  text-align: center;\r\n  max-width: 500px;\r\n  width: 100%;\r\n}\r\n\r\n.success-icon {\r\n  font-size: 60px;\r\n  color: #52c41a;\r\n  margin-bottom: 20px;\r\n}\r\n\r\n.error-icon {\r\n  font-size: 60px;\r\n  color: #f5222d;\r\n  margin-bottom: 20px;\r\n}\r\n\r\nh2 {\r\n  color: #333;\r\n  margin-bottom: 30px;\r\n  font-size: 24px;\r\n}\r\n\r\n.payment-info {\r\n  background: #f8f9fa;\r\n  border-radius: 8px;\r\n  padding: 20px;\r\n  margin: 20px 0;\r\n  text-align: left;\r\n}\r\n\r\n.info-item {\r\n  margin-bottom: 10px;\r\n  display: flex;\r\n  justify-content: space-between;\r\n  padding: 5px 0;\r\n  border-bottom: 1px solid #eee;\r\n}\r\n\r\n.info-item:last-child {\r\n  border-bottom: none;\r\n  margin-bottom: 0;\r\n}\r\n\r\n.label {\r\n  color: #666;\r\n  font-weight: 500;\r\n}\r\n\r\n.value {\r\n  color: #333;\r\n  font-weight: 600;\r\n}\r\n\r\n.amount {\r\n  color: #1890ff;\r\n  font-size: 18px;\r\n}\r\n\r\n.error-message {\r\n  color: #f5222d;\r\n  background: #fff1f0;\r\n  padding: 15px;\r\n  border-radius: 6px;\r\n  margin: 20px 0;\r\n}\r\n\r\n.actions {\r\n  margin-top: 30px;\r\n  display: flex;\r\n  gap: 15px;\r\n  justify-content: center;\r\n}\r\n\r\n.actions .el-button {\r\n  min-width: 120px;\r\n}\r\n\r\n/* 响应式设计 */\r\n@media (max-width: 768px) {\r\n  .success-card,\r\n  .error-card {\r\n    padding: 20px;\r\n  }\r\n\r\n  .actions {\r\n    flex-direction: column;\r\n  }\r\n\r\n  .actions .el-button {\r\n    width: 100%;\r\n  }\r\n}\r\n</style>"],"sourceRoot":"src/views"}]}